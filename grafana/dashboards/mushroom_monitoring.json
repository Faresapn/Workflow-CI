{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "1. Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "rate(inference_request_total[1m])",
          "legendFormat": "{{endpoint}} - {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "requests/sec",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "reqps"
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "2. Inference Duration",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "rate(inference_request_duration_seconds_sum[1m]) / rate(inference_request_duration_seconds_count[1m])",
          "legendFormat": "avg duration",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "seconds",
            "lineWidth": 2,
            "fillOpacity": 30
          },
          "unit": "s"
        }
      }
    },
    {
      "title": "3. Prediction Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "inference_prediction_class_total",
          "legendFormat": "Class {{predicted_class}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "right" },
        "pieType": "donut",
        "tooltip": { "mode": "single" }
      }
    },
    {
      "title": "4. Model Memory Usage",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "model_memory_usage_bytes",
          "legendFormat": "Model Size",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5000000 },
              { "color": "red", "value": 10000000 }
            ]
          },
          "unit": "bytes"
        }
      }
    },
    {
      "title": "5. Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "rate(inference_errors_total[1m])",
          "legendFormat": "{{error_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "errors/sec",
            "lineWidth": 2,
            "fillOpacity": 30
          }
        }
      }
    },
    {
      "title": "Alert: High Error Rate",
      "type": "alertlist",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 16 },
      "options": {
        "showOptions": "current",
        "maxItems": 5,
        "sortOrder": 1,
        "dashboardFilter": "",
        "folderId": null
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["mushroom", "ml", "monitoring"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Jakarta",
  "title": "Mushroom ML Monitoring Dashboard",
  "uid": "mushroom-ml-dashboard",
  "version": 1
}
